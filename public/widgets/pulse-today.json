{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "${pulseScore}",
              "size": "ExtraLarge",
              "weight": "Bolder",
              "color": "Accent"
            },
            {
              "type": "TextBlock",
              "text": "PULSE SCORE",
              "size": "Small",
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "📚 ${attendance} attendance",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "💸 ${todaySpend} spent today",
              "wrap": true,
              "spacing": "Small"
            },
            {
              "type": "TextBlock",
              "text": "🕘 ${nextClass}",
              "wrap": true,
              "spacing": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "⚠️ ${warningSubject}",
      "wrap": true,
      "color": "Attention",
      "isVisible": "${if(warningSubject != '', true, false)}"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Pulse",
      "url": "/dashboard"
    }
  ]
}
