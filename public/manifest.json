{
  "name": "DockIn — Your Campus, All in One Place",
  "short_name": "DockIn",
  "description": "Snaps, chats, groups and campus life for Bennett students — attendance and academics too.",
  "start_url": "/dashboard",
  "id": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#F5F3FF",
