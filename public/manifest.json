  "categories": ["education", "social", "productivity"],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Today's Attendance",
      "short_name": "Attendance",
      "url": "/attendance",
      "icons": [{ "src": "/icons/attendance.png", "sizes": "96x96" }]
    },
    {
      "name": "Friends",
      "short_name": "Friends",
      "url": "/friends",
      "icons": [{ "src": "/icons/finance.png", "sizes": "96x96" }]
    },
    {
      "name": "Chats",
      "short_name": "Chats",
      "url": "/chats",
      "icons": [{ "src": "/icons/academic.png", "sizes": "96x96" }]
    }
  ],
  "widgets": [
    {
      "name": "DockIn Today",
      "description": "Today's attendance, spend and classes at a glance",
      "tag": "pulse-today",
